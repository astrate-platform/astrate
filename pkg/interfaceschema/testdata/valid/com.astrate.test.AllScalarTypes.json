{
  "interface_name": "com.astrate.test.AllScalarTypes",
  "version_major": 1,
  "version_minor": 0,
  "type": "datastream",
  "ownership": "device",
  "description": "Astrate test fixture covering every scalar value type with assorted datastream attributes.",
  "mappings": [
    {
      "endpoint": "/double",
      "type": "double"
    },
    {
      "endpoint": "/integer",
      "type": "integer",
      "reliability": "guaranteed"
    },
    {
      "endpoint": "/boolean",
      "type": "boolean",
      "reliability": "unique"
    },
    {
      "endpoint": "/longinteger",
      "type": "longinteger",
      "retention": "volatile",
      "expiry": 60
    },
    {
      "endpoint": "/string",
      "type": "string",
      "retention": "stored",
      "expiry": 3600,
      "database_retention_policy": "use_ttl",
      "database_retention_ttl": 31536000
    },
    {
      "endpoint": "/binaryblob",
      "type": "binaryblob",
      "database_retention_policy": "no_ttl"
    },
    {
      "endpoint": "/datetime",
      "type": "datetime",
      "explicit_timestamp": true
    }
  ]
}
